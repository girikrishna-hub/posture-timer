<!--
  ════════════════════════════════════════════════════════════════════════════
  AndroidManifest.xml additions for full-screen alarm reminders
  ════════════════════════════════════════════════════════════════════════════

  Merge the <uses-permission> tags into the top-level <manifest> element.
  Merge the <activity> and <receiver> tags into the <application> element.
  ════════════════════════════════════════════════════════════════════════════
-->

<!-- ── Permissions (inside <manifest>) ────────────────────────────────── -->

<!-- Wake the CPU while in Doze (required for RTC_WAKEUP alarms) -->
<uses-permission android:name="android.permission.WAKE_LOCK" />

<!-- Exact alarms.
     SCHEDULE_EXACT_ALARM (no maxSdkVersion): declared on ALL API levels so
       the app always appears in Settings → Apps → Special access →
       Alarms & reminders — including on Android 13+ Samsung devices.
       Without maxSdkVersion="32", API 33+ devices no longer ignore this
       permission and the app is listed in Alarms & reminders normally.
     USE_EXACT_ALARM (API 33+): auto-granted at install, ensures
       canScheduleExactAlarms() returns true even if user revokes the above.
       Both together: scheduling always works AND the UI entry is visible. -->
<uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
<uses-permission android:name="android.permission.USE_EXACT_ALARM" />

<!-- Show notification over lock screen -->
<uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

<!-- Post notifications (required on Android 13+) -->
<uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

<!-- Vibration -->
<uses-permission android:name="android.permission.VIBRATE" />

<!-- Reschedule alarms after device reboot -->
<uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

<!-- Foreground service (used by the alarm receiver) -->
<uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

<!-- Ask system to ignore battery optimisation for this app -->
<uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />


<!-- ── Components (inside <application>) ──────────────────────────────── -->

<!-- Full-screen alarm activity -->
<activity
    android:name=".AlarmFullScreenActivity"
    android:showWhenLocked="true"
    android:turnScreenOn="true"
    android:exported="false"
    android:excludeFromRecents="true"
    android:launchMode="singleTop"
    android:screenOrientation="portrait"
    android:theme="@style/Theme.AppCompat.NoActionBar" />

<!-- Alarm broadcast receiver + boot-completed receiver -->
<receiver
    android:name=".AlarmReceiver"
    android:exported="true">
    <intent-filter>
        <action android:name="android.intent.action.BOOT_COMPLETED" />
        <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
    </intent-filter>
</receiver>

<!-- Deep-link handler for Clerk OAuth callbacks (e.g. Google Sign-In).
     After the in-app browser completes the OAuth flow, Clerk redirects to
     posture-timer://oauth-callback?__clerk_ticket=… and Android routes it
     here so the app can complete sign-in without a page navigation. -->
<intent-filter android:autoVerify="false">
    <action android:name="android.intent.action.VIEW" />
    <category android:name="android.intent.category.DEFAULT" />
    <category android:name="android.intent.category.BROWSABLE" />
    <data android:scheme="posture-timer" />
</intent-filter>
