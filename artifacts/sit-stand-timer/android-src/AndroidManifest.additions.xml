<!--
  ════════════════════════════════════════════════════════════════════════════
  AndroidManifest.xml additions for full-screen alarm reminders
  ════════════════════════════════════════════════════════════════════════════

  Merge the <uses-permission> tags into the top-level <manifest> element.
  Merge the <activity> and <receiver> tags into the <application> element.
  ════════════════════════════════════════════════════════════════════════════
-->

<!-- ── Permissions (inside <manifest>) ────────────────────────────────── -->

<!-- Wake the CPU while in Doze (required for RTC_WAKEUP alarms) -->
<uses-permission android:name="android.permission.WAKE_LOCK" />

<!-- Exact alarms.
     Android 12 (API 31–32): SCHEDULE_EXACT_ALARM — user-revocable, appears
       in Settings → Apps → Special access → Alarms & reminders.
     Android 13+ (API 33+): USE_EXACT_ALARM — system-granted at install,
       NOT user-revocable. On Samsung/One UI the Alarms & reminders toggle
       appears GREYED (locked on) when this is declared; that is the
       expected, working state. canScheduleExactAlarms() returns true.

     IMPORTANT: USE_EXACT_ALARM is evaluated at install time. After adding
     it, a full uninstall + reinstall is required — install-over does not
     re-grant. The prior comment in this file ("intentionally omitted")
     was based on outdated Play-Store guidance and did not apply to a
     sideloaded personal-use APK. -->
<uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM"
    android:maxSdkVersion="32" />
<uses-permission android:name="android.permission.USE_EXACT_ALARM" />

<!-- Show notification over lock screen -->
<uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

<!-- Post notifications (required on Android 13+) -->
<uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

<!-- Vibration -->
<uses-permission android:name="android.permission.VIBRATE" />

<!-- Reschedule alarms after device reboot -->
<uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

<!-- Foreground service (used by the alarm receiver) -->
<uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

<!-- Ask system to ignore battery optimisation for this app -->
<uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />


<!-- ── Components (inside <application>) ──────────────────────────────── -->

<!-- Full-screen alarm activity -->
<activity
    android:name=".AlarmFullScreenActivity"
    android:showWhenLocked="true"
    android:turnScreenOn="true"
    android:exported="false"
    android:excludeFromRecents="true"
    android:launchMode="singleTop"
    android:screenOrientation="portrait"
    android:theme="@style/Theme.AppCompat.NoActionBar" />

<!-- Alarm broadcast receiver + boot-completed receiver -->
<receiver
    android:name=".AlarmReceiver"
    android:exported="true">
    <intent-filter>
        <action android:name="android.intent.action.BOOT_COMPLETED" />
        <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
    </intent-filter>
</receiver>

<!-- Deep-link handler for Clerk OAuth callbacks (e.g. Google Sign-In).
     After the in-app browser completes the OAuth flow, Clerk redirects to
     posture-timer://oauth-callback?__clerk_ticket=… and Android routes it
     here so the app can complete sign-in without a page navigation. -->
<intent-filter android:autoVerify="false">
    <action android:name="android.intent.action.VIEW" />
    <category android:name="android.intent.category.DEFAULT" />
    <category android:name="android.intent.category.BROWSABLE" />
    <data android:scheme="posture-timer" />
</intent-filter>
